# Micro-X Agent Demo
Output demo.gif

Set Width 1200
Set Height 600
Set FontSize 16
Set Shell cmd.exe
Set TypingSpeed 40
Set Fps 10

# Start the agent
Type "run.bat --config config-standard-no-summarization-sonnet.json"
Enter
Sleep 10s

# Type the prompt
Type "Build an authentication system"
Sleep 1s
Enter
Sleep 15s

# Select option 3
Type "3"
Enter
Sleep 15s
