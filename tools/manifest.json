{
  "jobserve-processor": {
    "tool_name": "jobserve-processor",
    "description": "Processes JobServe job alert emails, retrieves full job specs from JobServe pages, and produces a ranked markdown report.",
    "created": "2026-05-14",
    "input_schema": {
      "type": "object",
      "properties": {},
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "server": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "tsx",
        "src/index.ts",
        "--config",
