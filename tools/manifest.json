{
  "jobserve_email_processor": {
    "tool_name": "jobserve_email_processor",
    "description": "Parses JobServe job-alert emails into individual jobs, fetches each full specification, scores them against a CV with rank reasons, drafts a brief cover letter per job, and writes a dated markdown report per email date.",
    "created": "2026-05-22",
    "input_schema": {
      "type": "object",
      "properties": {},
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "server": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "tsx",
        "src/index.ts",
        "--config",
        "../../config.json"
      ],
      "cwd": "tools/jobserve_email_processor/"
    }
  },
  "jobserve_rss_processor": {
    "tool_name": "jobserve_rss_processor",
    "description": "JobServe RSS processor \u2014 exposes process_feed (read the feed, score new jobs, write banded reports) and search (query saved job records for a given date by minimum score).",
    "created": "2026-05-22",
    "input_schema": null,
    "tools": [
      {
        "tool_name": "process_feed",
        "description": "Reads job items from a JobServe RSS feed and rebuilds a score-banded markdown report per date \u2014 each new job gets an LLM suitability score (0-10), a rank reason, and a brief cover letter judged against a CV. Idempotent: jobs already recorded are never re-scored.",
        "input_schema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        }
      },
      {
        "tool_name": "search",
        "description": "Search saved JobServe job records for a given date. Reads the YYYY-MM-DD-js-rss-data.json sidecar in the configured output_dir, filters to jobs scoring at or above minScore, sorts by score descending, and returns up to maxItems entries with full job data (title, link, location, rate, score, reason, cover letter, description).",
        "input_schema": {
          "type": "object",
          "properties": {
            "date": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "Date of the sidecar file to read, in YYYY-MM-DD format."
            },
            "minScore": {
              "type": "number",
              "minimum": 0,
              "maximum": 10,
              "description": "Minimum job score (0-10) to include. Defaults to 0 (no floor)."
            },
            "maxItems": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "description": "Maximum number of jobs to return, ordered by score desc. Defaults to 50."
            }
          },
          "required": [
            "date"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        }
      }
    ],
    "server": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "tsx",
        "src/index.ts",
        "--config",
        "../../config.json"
      ],
      "cwd": "tools/jobserve_rss_processor/"
    }
  },
  "gmail_receipt_extractor": {
    "tool_name": "gmail_receipt_extractor",
    "description": "Search Gmail for receipt emails on a given date, extract PDF attachment data, and produce a markdown expense report.",
    "created": "2026-06-02",
    "input_schema": {
      "type": "object",
      "properties": {
        "email_date": {
          "type": "string",
          "description": "Date to search emails, format YYYY-MM-DD (required)"
        },
        "subject_pattern": {
          "type": "string",
          "default": "Your Trainline receipt",
          "description": "Email subject pattern to search for"
        },
        "output_file": {
          "type": "string",
          "default": "expense_report.md",
          "description": "Output markdown file path"
        },
        "attachment_dir": {
          "type": "string",
          "default": "attachments",
          "description": "Directory for downloaded PDF attachments"
        }
      },
      "required": [
        "email_date"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "tools": [
      {
        "tool_name": "gmail_receipt_extractor",
        "description": "Search Gmail for receipt emails on a given date, extract PDF attachment data, and produce a markdown expense report.",
        "input_schema": {
          "type": "object",
          "properties": {
            "email_date": {
              "type": "string",
              "description": "Date to search emails, format YYYY-MM-DD (required)"
            },
            "subject_pattern": {
              "type": "string",
              "default": "Your Trainline receipt",
              "description": "Email subject pattern to search for"
            },
            "output_file": {
              "type": "string",
              "default": "expense_report.md",
              "description": "Output markdown file path"
            },
            "attachment_dir": {
              "type": "string",
              "default": "attachments",
              "description": "Directory for downloaded PDF attachments"
            }
          },
          "required": [
            "email_date"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        }
      }
    ],
    "server": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "tsx",
        "src/index.ts",
        "--config",
        "../../config.json"
      ],
      "cwd": "tools/gmail_receipt_extractor/"
    }
  },
  "linkedin_job_processor": {
    "tool_name": "linkedin_job_processor",
    "description": "Fetch LinkedIn job details, score against a CV, and generate cover letters for each job URL.",
    "created": "2026-06-04",
    "input_schema": {
      "type": "object",
      "properties": {
        "job_urls": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of LinkedIn job URLs to process"
        },
        "cv_path": {
          "type": "string",
          "description": "Path to the CV markdown file"
        },
        "output_path": {
          "type": "string",
          "description": "Where to write the JSON output"
        },
        "batch_size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "default": 5,
          "description": "Jobs to fetch in parallel per batch"
        }
      },
      "required": [
        "job_urls",
        "cv_path",
        "output_path"
      ],
      "additionalProperties": false,
