    "description": "Scrapes job listings from JobServe emails and appends them to a markdown file.",
    "created": "2026-05-06",
    "server": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "tsx",
        "src/index.ts",
        "--config",
        "../../config.json"
      ],
      "cwd": "tools/jobserve_email_scraper/"
    }
  },
