{
  "Base": "config-base.json",

  "SemanticRoutingEnabled": true,
  "SemanticRoutingStrategy": "rules+keywords",
  "RoutingConfidenceThreshold": 0.6,
  "RoutingFeedbackEnabled": true,

  "PromptCachingEnabled": true,
  "CompactionStrategy": "summarize",
  "CompactionThresholdTokens": 25000,

  "ToolResultSummarizationEnabled": true,
  "ToolResultSummarizationThreshold": 4000,

  "LogLevel": "INFO"
}
