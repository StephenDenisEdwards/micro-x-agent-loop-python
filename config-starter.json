{
  "Provider": "anthropic",
  "Model": "claude-sonnet-4-5-20250929",
  "MaxTokens": 8192,
  "Temperature": 0.7,
  "CompactionStrategy": "summarize",
  "MemoryEnabled": true,
  "PromptCachingEnabled": true,
  "CompactionModel": "claude-haiku-4-5-20251001",
  "SmartCompactionTriggerEnabled": true,
  "McpServers": {
    "filesystem": {
      "command": "node",
      "args": ["mcp_servers/ts/packages/filesystem/dist/index.js"]
    },
    "web": {
      "command": "node",
      "args": ["mcp_servers/ts/packages/web/dist/index.js"]
    },
    "google": {
      "command": "node",
      "args": ["mcp_servers/ts/packages/google/dist/index.js"],
      "env": {
        "GOOGLE_TOKEN_BASE_DIR": "."
      }
    }
  }
}
